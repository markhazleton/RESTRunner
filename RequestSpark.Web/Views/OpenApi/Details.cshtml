@model RequestSpark.Web.Models.ViewModels.OpenApiDetailsViewModel
@{
    ViewData["Title"] = Model.Spec.Title + " — Details";
}

<div class="container-fluid">
    <!-- ── Header ──────────────────────────────────────────────────────── -->
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h2 mb-1">@Model.Spec.Title</h1>
            <span class="badge bg-light text-dark border me-1" title="Format detected from the root 'openapi' or 'swagger' property">@Model.Spec.SpecFormat</span>
            <span class="badge @(Model.Spec.IsActive ? "bg-success" : "bg-secondary")">@(Model.Spec.IsActive ? "Active" : "Inactive")</span>
        </div>
        <div class="d-flex gap-2">
            <a href="/OpenApi/Test/@Model.Spec.Id" class="btn btn-primary">Test Endpoints</a>
            <a href="/OpenApi/Edit/@Model.Spec.Id" class="btn btn-outline-secondary">Edit</a>
            <a href="/OpenApi" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>

    <div class="row g-4">
        <!-- ── Left: spec info + endpoints ─────────────────────────────── -->
        <div class="col-lg-8">

            <!-- Specification summary -->
            <div class="card mb-4">
                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                    Specification Summary
                    <span class="badge bg-light text-dark border small fw-normal" title="The spec format is detected from the root property of the JSON file">
                        @Model.Spec.SpecFormat
                    </span>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <small class="text-muted d-block">
                                API Version
                                <span tabindex="0" data-bs-toggle="tooltip"
                                      title="The version of your API, declared in info.version. This is your API's version, not the OpenAPI format version.">&#9432;</span>
                            </small>
                            <strong>@Model.Spec.Version</strong>
                        </div>
                        <div class="col-sm-4">
                            <small class="text-muted d-block">
                                Spec Format
                                <span tabindex="0" data-bs-toggle="tooltip"
                                      title="OpenAPI 3.x is the current standard. Swagger 2.0 is the older format — both are fully supported.">&#9432;</span>
                            </small>
                            <strong>@Model.Spec.SpecFormat</strong>
                        </div>
                        <div class="col-sm-4">
                            <small class="text-muted d-block">
                                Endpoints
                                <span tabindex="0" data-bs-toggle="tooltip"
                                      title="Each unique combination of an HTTP method and a path counts as one endpoint (operation). E.g. GET /users and POST /users are two separate endpoints.">&#9432;</span>
                            </small>
                            <strong>@Model.Spec.EndpointCount</strong>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Spec.Description))
                    {
                        <hr class="mt-0">
                        <p class="mb-0 text-muted">@Model.Spec.Description</p>
                    }

                    <!-- HTTP methods legend -->
                    @if (Model.Spec.HttpMethods.Any())
                    {
                        <hr class="mt-2 mb-2">
                        <div class="d-flex flex-wrap gap-2 align-items-center">
                            <small class="text-muted me-1">HTTP methods used:</small>
                            @foreach (var m in Model.Spec.HttpMethods.OrderBy(x => x))
                            {
                                <span class="badge @MethodBadge(m)"
                                      title="@MethodExplain(m)">@m</span>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- What are Tags? callout -->
            <div class="alert alert-light border mb-3 small">
                <strong>About Tags</strong> &mdash; In OpenAPI, <code>tags</code> are labels that group related operations together.
                For example, all endpoints about users might share the tag <em>Users</em>, and payment endpoints share <em>Payments</em>.
                Tags appear as section headers in documentation tools and in the Test Runner sidebar below.
                An endpoint without a tag is shown under <em>Default</em>.
            </div>

            <!-- Endpoints by tag -->
            @if (Model.Structure.TagGroups.Any())
            {
                <div class="accordion" id="endpointAccordion">
                    @foreach (var (group, gi) in Model.Structure.TagGroups.Select((g, i) => (g, i)))
                    {
                        var collapseId = $"group_{gi}";
                        <div class="accordion-item mb-2 border rounded">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(gi > 0 ? "collapsed" : "")" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                    <strong>@group.Name</strong>
                                    <span class="badge bg-secondary ms-2">@group.Endpoints.Count</span>
                                    @if (!string.IsNullOrEmpty(group.Description))
                                    {
                                        <span class="ms-3 text-muted fw-normal small">@group.Description</span>
                                    }
                                </button>
                            </h2>
                            <div id="@collapseId" class="accordion-collapse collapse @(gi == 0 ? "show" : "")">
                                <div class="accordion-body p-0">
                                    @foreach (var ep in group.Endpoints)
                                    {
                                        <div class="border-bottom p-3 @(ep.IsDeprecated ? "opacity-50" : "")">
                                            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                                <span class="badge @MethodBadge(ep.Method) font-monospace"
                                                      style="min-width:64px"
                                                      title="@MethodExplain(ep.Method)">@ep.Method</span>
                                                <code class="text-body fs-6">@ep.Path</code>
                                                @if (ep.IsDeprecated)
                                                {
                                                    <span class="badge bg-secondary"
                                                          title="Deprecated endpoints still work but should not be used in new code. The API provider has marked them for removal.">
                                                        deprecated
                                                    </span>
                                                }
                                                @if (!string.IsNullOrEmpty(ep.OperationId))
                                                {
                                                    <span class="text-muted small font-monospace"
                                                          title="operationId: a unique machine-readable name for this operation, used by code generators">
                                                        @ep.OperationId
                                                    </span>
                                                }
                                            </div>

                                            @if (!string.IsNullOrEmpty(ep.Summary))
                                            {
                                                <div class="text-muted small ms-1 mb-1">@ep.Summary</div>
                                            }

                                            @if (ep.Parameters.Any())
                                            {
                                                <div class="mt-1 ms-1 d-flex flex-wrap gap-1">
                                                    @foreach (var p in ep.Parameters.Where(x => x.Required))
                                                    {
                                                        <span class="badge bg-light text-danger border"
                                                              title="@ParamDesc(p.In) — Required · type: @p.Type">
                                                            @p.Name
                                                            <span class="text-muted fw-normal">(@p.In)</span>
                                                        </span>
                                                    }
                                                    @foreach (var p in ep.Parameters.Where(x => !x.Required))
                                                    {
                                                        <span class="badge bg-light text-muted border"
                                                              title="@ParamDesc(p.In) — Optional · type: @p.Type">
                                                            @p.Name
                                                            <span class="fw-normal">(@p.In)</span>
                                                        </span>
                                                    }
                                                </div>
                                            }

                                            @if (ep.Responses.Any())
                                            {
                                                <div class="mt-2 ms-1 d-flex flex-wrap gap-1">
                                                    @foreach (var (code, desc) in ep.Responses)
                                                    {
                                                        <span class="badge @ResponseBadge(code)" title="@desc">@code</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">No endpoints could be parsed from this specification.</div>
            }

            <!-- Parameter legend -->
            <div class="card mt-4 border-secondary">
                <div class="card-header fw-semibold">Parameter Location Reference</div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        OpenAPI parameters are categorised by <em>where</em> they appear in the HTTP request.
                        Hover the parameter badges in the endpoint list above to see this description.
                    </p>
                    <div class="row g-3 small">
                        <div class="col-sm-6">
                            <div class="p-2 border rounded h-100">
                                <strong><code>path</code></strong>
                                <p class="text-muted mb-0 mt-1">Part of the URL itself, inside curly braces.
                                <code>/users/<strong>{id}</strong></code> &rarr; you supply <code>id=42</code> and the URL becomes
                                <code>/users/42</code>. Always required by definition.</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 border rounded h-100">
                                <strong><code>query</code></strong>
                                <p class="text-muted mb-0 mt-1">Appended after <code>?</code> in the URL.
                                <code>/users?<strong>limit=20&amp;offset=0</strong></code>.
                                Typically used for filtering, sorting, and pagination. Usually optional.</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 border rounded h-100">
                                <strong><code>header</code></strong>
                                <p class="text-muted mb-0 mt-1">Sent as an HTTP request header alongside the path and body.
                                Common examples: <code>Accept</code>, <code>X-Request-Id</code>, <code>X-API-Version</code>.
                                Authentication headers like <code>Authorization</code> are often expressed here.</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 border rounded h-100">
                                <strong><code>cookie</code></strong>
                                <p class="text-muted mb-0 mt-1">Passed in the browser <code>Cookie</code> header.
                                Rarely used in modern API design; session tokens and CSRF tokens are the most
                                common cases.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Right sidebar ────────────────────────────────────────────── -->
        <div class="col-lg-4">

            <!-- Actions -->
            <div class="card mb-3">
                <div class="card-header fw-semibold">Actions</div>
                <div class="card-body d-grid gap-2">
                    <a href="/OpenApi/Test/@Model.Spec.Id" class="btn btn-primary">Interactive Test Runner</a>
                    <a href="/OpenApi/Download/@Model.Spec.Id" class="btn btn-outline-success">Download Spec File</a>
                    <a href="/OpenApi/Edit/@Model.Spec.Id" class="btn btn-outline-secondary">Edit Metadata</a>
                    <a href="/OpenApi/Delete/@Model.Spec.Id" class="btn btn-outline-danger">Delete</a>
                </div>
            </div>

            <!-- Servers -->
            @if (Model.Structure.Servers.Any())
            {
                <div class="card mb-3">
                    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                        Servers
                        <span tabindex="0" data-bs-toggle="tooltip" class="text-muted"
                              title="The base URL(s) where this API is hosted. All endpoint paths are appended to the active server URL. Multiple servers let you target different environments (production, staging, sandbox).">
                            &#9432; What is this?
                        </span>
                    </div>
                    <div class="card-body small">
                        <p class="text-muted mb-2">
                            In OpenAPI 3.x, <code>servers</code> lists all environments where the API is available.
                            Every endpoint path is appended to the selected server URL during testing.
                        </p>
                        @foreach (var srv in Model.Structure.Servers)
                        {
                            <div class="d-flex align-items-center gap-1 mb-1">
                                <code class="@(srv == Model.Spec.DefaultBaseUrl ? "text-primary" : "")">@srv</code>
                                @if (srv == Model.Spec.DefaultBaseUrl)
                                {
                                    <span class="badge bg-primary" style="font-size:.6rem">default</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Security Schemes -->
            @if (Model.Structure.SecuritySchemes.Any())
            {
                <div class="card mb-3">
                    <div class="card-header fw-semibold">Security Schemes</div>
                    <div class="card-body small">
                        <p class="text-muted mb-2">
                            Security schemes describe <em>how</em> a caller must authenticate.
                            They are declared in <code>components.securitySchemes</code> and referenced
                            from individual operations or the global <code>security</code> block.
                        </p>
                        @foreach (var (name, type) in Model.Structure.SecuritySchemes)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                <div>
                                    <code>@name</code>
                                    <div class="text-muted" style="font-size:.72rem">@SecuritySchemeDesc(type)</div>
                                </div>
                                <span class="badge bg-light text-dark border">@type</span>
                            </div>
                        }
                        <div class="alert alert-light py-2 mb-0 small">
                            When testing, use the <strong>Auth</strong> bar in the Test Runner to supply the appropriate
                            token or key for the active scheme.
                        </div>
                    </div>
                </div>
            }

            <!-- Statistics -->
            <div class="card mb-3">
                <div class="card-header fw-semibold">Statistics</div>
                <div class="card-body">
                    <div class="row text-center mb-3">
                        <div class="col-6">
                            <div class="h4 text-primary">@Model.Spec.EndpointCount</div>
                            <small class="text-muted">Operations</small>
                        </div>
                        <div class="col-6">
                            <div class="h4 text-success">@Model.Structure.TagGroups.Count</div>
                            <small class="text-muted">Tag Groups</small>
                        </div>
                    </div>
                    <div class="small">
                        <div class="text-muted mb-1">HTTP methods used in this spec:</div>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            @foreach (var m in Model.Spec.HttpMethods)
                            {
                                <span class="badge @MethodBadge(m)" title="@MethodExplain(m)">@m</span>
                            }
                        </div>
                        <div class="text-muted">File size: @((Model.Spec.FileSize / 1024.0).ToString("F1")) KB</div>
                        <div class="text-muted">Uploaded: @Model.Spec.UploadedAt.ToString("MMM dd, yyyy 'at' HH:mm")</div>
                    </div>
                </div>
            </div>

            <!-- User tags -->
            @if (Model.Spec.UserTags.Any())
            {
                <div class="card mb-3">
                    <div class="card-header fw-semibold">Your Tags</div>
                    <div class="card-body">
                        @foreach (var tag in Model.Spec.UserTags)
                        {
                            <span class="badge bg-light text-dark border me-1 mb-1">@tag</span>
                        }
                    </div>
                </div>
            }

            <!-- Quick reference -->
            <div class="card border-secondary">
                <div class="card-header fw-semibold">HTTP Method Quick Reference</div>
                <div class="card-body p-0">
                    <table class="table table-sm table-bordered mb-0 small">
                        <tbody>
                            <tr><td><span class="badge bg-success">GET</span></td><td>Read / retrieve a resource. Safe &amp; idempotent.</td></tr>
                            <tr><td><span class="badge bg-primary">POST</span></td><td>Create a new resource or trigger an action.</td></tr>
                            <tr><td><span class="badge bg-warning text-dark">PUT</span></td><td>Replace a resource entirely. Idempotent.</td></tr>
                            <tr><td><span class="badge bg-info text-dark">PATCH</span></td><td>Partially update a resource.</td></tr>
                            <tr><td><span class="badge bg-danger">DELETE</span></td><td>Remove a resource. Idempotent.</td></tr>
                            <tr><td><span class="badge bg-secondary">HEAD</span></td><td>Like GET but returns headers only &mdash; no body.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el =>
    new bootstrap.Tooltip(el));
</script>
}

@functions {
    string MethodBadge(string method) => method.ToUpper() switch
    {
        "GET" => "bg-success",
        "POST" => "bg-primary",
        "PUT" => "bg-warning text-dark",
        "PATCH" => "bg-info text-dark",
        "DELETE" => "bg-danger",
        _ => "bg-secondary"
    };

    string MethodExplain(string method) => method.ToUpper() switch
    {
        "GET" => "GET — Retrieve a resource. Read-only; no side effects.",
        "POST" => "POST — Create a new resource, or submit data to trigger an action.",
        "PUT" => "PUT — Replace an existing resource entirely. Idempotent.",
        "PATCH" => "PATCH — Apply a partial update to an existing resource.",
        "DELETE" => "DELETE — Remove a resource. Idempotent.",
        "HEAD" => "HEAD — Identical to GET but the response has no body. Used to check existence or headers.",
        "OPTIONS" => "OPTIONS — Returns the HTTP methods supported by this endpoint. Used for CORS pre-flight.",
        _ => method
    };

    string ParamDesc(string loc) => loc switch
    {
        "path" => "Path parameter — embedded in the URL, e.g. /users/{id}",
        "query" => "Query parameter — appended after ?, e.g. ?limit=20",
        "header" => "Header parameter — sent as an HTTP header",
        "cookie" => "Cookie parameter — sent in the Cookie header",
        _ => loc + " parameter"
    };

    string ResponseBadge(string code) => code switch
    {
        var c when c.StartsWith("2") => "bg-success",
        var c when c.StartsWith("3") => "bg-info text-dark",
        var c when c.StartsWith("4") => "bg-warning text-dark",
        var c when c.StartsWith("5") => "bg-danger",
        _ => "bg-secondary"
    };

    string SecuritySchemeDesc(string type) => type.ToLower() switch
    {
        "http" => "HTTP authentication (Bearer JWT or Basic)",
        "apikey" => "API Key — passed in a header, query param, or cookie",
        "oauth2" => "OAuth 2.0 — token-based delegated authorization",
        "openidconnect" => "OpenID Connect — identity layer on top of OAuth 2.0",
        "bearer" => "Bearer token (e.g. JWT) in the Authorization header",
        "basic" => "HTTP Basic — Base64-encoded username:password",
        _ => type
    };
}

