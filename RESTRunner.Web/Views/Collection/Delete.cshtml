@model RESTRunner.Web.Models.CollectionMetadata
@{
    ViewData["Title"] = "Delete Collection";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-danger">Delete Collection</h1>
        <a href="/Collection" class="btn btn-outline-secondary">Back to List</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Confirm Deletion</h5>
                </div>
                <div class="card-body">
                    <p class="text-danger fw-bold">Are you sure you want to delete this collection? This action cannot be undone.</p>

                    <dl class="row">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">File</dt>
                        <dd class="col-sm-8"><code>@Model.FileName</code></dd>

                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <dt class="col-sm-4">Description</dt>
                            <dd class="col-sm-8">@Model.Description</dd>
                        }

                        <dt class="col-sm-4">Requests</dt>
                        <dd class="col-sm-8">@Model.RequestCount</dd>

                        <dt class="col-sm-4">Uploaded</dt>
                        <dd class="col-sm-8">@Model.UploadedAt.ToString("MMM dd, yyyy 'at' HH:mm")</dd>

                        <dt class="col-sm-4">Size</dt>
                        <dd class="col-sm-8">@((Model.FileSize / 1024.0).ToString("F1")) KB</dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        @Html.AntiForgeryToken()
                        <div class="d-flex justify-content-between">
                            <a href="/Collection/Details/@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-danger">Delete Collection</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
