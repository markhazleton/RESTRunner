@model RESTRunner.Web.Models.OpenApiSpec
@{
    ViewData["Title"] = "Edit — " + Model.Title;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">Edit Specification</h1>
        <a href="/OpenApi/Details/@Model.Id" class="btn btn-outline-secondary">Back to Details</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FileName" />
                <input type="hidden" asp-for="FilePath" />
                <input type="hidden" asp-for="FileSize" />
                <input type="hidden" asp-for="Version" />
                <input type="hidden" asp-for="SpecFormat" />
                <input type="hidden" asp-for="EndpointCount" />
                <input type="hidden" asp-for="ContentHash" />
                <input type="hidden" asp-for="UploadedAt" />
                <input type="hidden" asp-for="UploadedBy" />

                <div class="card mb-3">
                    <div class="card-header fw-semibold">Metadata</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" required>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="defaultBaseUrl" class="form-label">Default Base URL</label>
                            <input type="text" id="defaultBaseUrl" name="defaultBaseUrl"
                                   class="form-control" value="@Model.DefaultBaseUrl"
                                   placeholder="https://api.example.com">
                            <div class="form-text">
                                Available servers:
                                @foreach (var srv in Model.AvailableServers)
                                {
                                    <a href="#" class="me-2 small" onclick="document.getElementById('defaultBaseUrl').value='@srv';return false;">@srv</a>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="userTagsString" class="form-label">Tags</label>
                            <input type="text" id="userTagsString" name="userTagsString"
                                   class="form-control"
                                   value="@string.Join(", ", Model.UserTags)"
                                   placeholder="api, v2, internal">
                            <div class="form-text">Comma-separated organisational tags</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch">
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Read-only spec info -->
                <div class="card mb-3 bg-light">
                    <div class="card-header fw-semibold">Specification Info (read-only)</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-sm-4">
                                <small class="text-muted">Format</small>
                                <div><code>@Model.SpecFormat</code></div>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted">API Version</small>
                                <div><code>@Model.Version</code></div>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted">Endpoints</small>
                                <div><strong>@Model.EndpointCount</strong></div>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-sm-4">
                                <small class="text-muted">File</small>
                                <div><code class="small">@Model.FileName</code></div>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted">Size</small>
                                <div>@((Model.FileSize / 1024.0).ToString("F1")) KB</div>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted">Uploaded</small>
                                <div>@Model.UploadedAt.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/OpenApi/Details/@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
